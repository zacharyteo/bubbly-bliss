<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Confirmation - Bubbly Bliss</title>

</head>
<body>
  <nav>
      <a href="/">🧋 Bubbly Bliss</a>
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/account">Account</a></li>
        <li><a href="/menu">Menu</a></li>
        <li><a href="/reviews">Reviews</a></li>
      </ul>
    </nav>

  <h1>Order Confirmed ✅</h1>
  <p>Thank you for your order, <%= customer.name %>! We'll prepare your bubble tea and have it ready for pickup soon.</p>
  <br>
  <form action="/reviews/create" method="GET">
    <input type="hidden" name="orderId" value="<%= order._id %>">
    <input type="hidden" name="customerId" value="<%= customer._id %>">
    <input type="hidden" name="name" value="<%= customer.name %>">
    <button type="submit">Love our tea? Give us a five-star review</button>
  </form>
  <br>
  <table border="1">
    <tr>
      <th>Order ID</th> 
      <td><%= order.orderId %></td>
    </tr>
    <tr>
      <th>Customer Email</th>
      <td> <%= customer.email %> </td>
    </tr>
    <tr>
      <th>Status</th>
      <td>Confirmed ✓</td>
    </tr>
    <tr>
      <th>Order Time</th>
      <td><%= new Date(order.createdAt).toLocaleString() %></td>
    </tr>
  </table>
   
  <h2>Order Items</h2>
  <ul>
    <% orderItems.forEach(item => { %>
      <li>
        <%= item.name %> <br>
        <small>Qty: <%= item.quantity %> | Sugar: <%= item.sugarLevel %> | Ice: <%= item.iceLevel %></small>
        <br>$<%= (item.price * item.quantity).toFixed(2) %>
      </li>
    <% }); %>
    </ul>
    
  <footer>
    <p>&copy; 2026 Bubbly Bliss. All rights reserved.</p>
  </footer>
</body>
</html>
