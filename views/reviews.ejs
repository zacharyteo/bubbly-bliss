<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Reviews - Bubbly Bliss</title>
  
</head>
<body>
  <nav>
    <a href="/">🧋 Bubbly Bliss</a>
    <ul>
      <li><a href="/about">About</a></li>
      <li><a href="/account">Account</a></li>
      <li><a href="/menu">Menu</a></li>
      <li><a href="/reviews">Reviews</a></li>
    </ul>
  </nav>

 
  <h1>⭐ Customer Reviews</h1>
  <p>See what our customers think about our bubble teas</p>

  <% if(reviews && reviews.length > 0) { %>
   
          <% reviews.forEach(review => { %>
              <p><%= review.name %></p>
              <p><%= new Date(review.createdAt).toLocaleDateString() %></p>
              <p><%= Array(review.rating).fill('⭐').join('') %></p>
              <p><%= review.comment || 'No comment provided' %></p>
              <hr> 
          <% }); %>
           
        <hr>
      
  <% } else { %>
    
 
    <p>📝 No reviews available yet. Start ordering and sharing your experiences!</p>
    <a href="/menu">Order Now</a>
    
  <% } %>
 

  <footer>
    <p>&copy; 2026 Bubbly Bliss. All rights reserved.</p>
  </footer>


</body>
</html>
